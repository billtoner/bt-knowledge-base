#!/usr/bin/env zsh
# kb — get/put for the bt-knowledge-base notes repo.
#
# A curated, searchable "select shell history": commands worth keeping, each
# paired with the reason you kept it (the inline `# intent` comment), living in
# tool-notes/*.md under the three-tier structure (see CLAUDE.md).
#
# Subcommands:
#   kb find <terms...>           Search examples; returns the command + intent + a
#                                tool-notes/<x>.md:<line> pointer you can click/open.
#   kb add  <tool> [opts]        Editor-first capture. Opens the right note at a ready
#                                template line; scaffolds + wires a new tool/category.
#   kb open <tool>               Open a tool note in $EDITOR.
#   kb help                      This text.
#
# add options:
#   --section "<Heading>"        Section to capture under (default: last bash block).
#   --category "<Category>"      Category for a NEW tool (else prompted).
#   --desc "<one-liner>"         Description for a NEW tool's title line.
#   --dry-run                    Print planned file changes; write nothing.
#
# Install: put bin/ on PATH, or:  alias kb="$HOME/Documents/repos/bt-knowledge-base/bin/kb"

emulate -L zsh
setopt extendedglob
set -o pipefail

# --- repo root: bin/kb -> repo is the parent of bin/ ---
REPO="${0:A:h:h}"
[[ -d "$REPO/tool-notes" ]] || REPO="$HOME/Documents/repos/bt-knowledge-base"
# --- knowledge-base roots (multi-repo: public + private) ---
# Sources, in priority order:
#   1. $KB_ROOTS env       — "label=path:label=path"  (or just "path:path")
#   2. ~/.config/kb/roots  — one "label = path" (or bare "path") per line; # comments ok
#   3. fallback            — the repo this script lives in
# The FIRST root is the default write target ("public"); private notes need --private.
typeset -ga KB_LABELS KB_PATHS

_kb_add_root() {
    local spec="$1" label path
    if [[ "$spec" == *=* ]]; then label="${spec%%=*}"; path="${spec#*=}"
    else path="$spec"; label=""; fi
    label="${label##[[:space:]]##}"; label="${label%%[[:space:]]##}"
    path="${path##[[:space:]]##}";   path="${path%%[[:space:]]##}"
    path="${path/#\~/$HOME}"
    [[ -z "$label" ]] && label="${path:t}"
    [[ -d "$path/tool-notes" ]] || return 0       # skip roots that aren't set up yet
    KB_LABELS+=("$label"); KB_PATHS+=("$path")
}

kb_load_roots() {
    KB_LABELS=(); KB_PATHS=()
    local cfg="${KB_CONFIG:-$HOME/.config/kb/roots}" entry line
    if [[ -n "${KB_ROOTS:-}" ]]; then
        for entry in ${(s.:.)KB_ROOTS}; do _kb_add_root "$entry"; done
    elif [[ -f "$cfg" ]]; then
        while IFS= read -r line; do
            line="${line%%\#*}"; line="${line## }"; line="${line%% }"
            [[ -n "$line" ]] && _kb_add_root "$line"
        done < "$cfg"
    fi
    (( ${#KB_PATHS} )) || { KB_LABELS+=("${REPO:t}"); KB_PATHS+=("$REPO"); }
}

# Resolve a write target. "" => first root (default/public); "private"/"priv" =>
# a private-looking root; otherwise an exact label match. Echoes "label<TAB>path".
kb_root_for() {
    local sel="$1" i
    if [[ -z "$sel" ]]; then
        print -r -- "${KB_LABELS[1]}"$'\t'"${KB_PATHS[1]}"; return 0
    fi
    for i in {1..${#KB_PATHS}}; do
        [[ "${KB_LABELS[$i]}" == "$sel" ]] && { print -r -- "${KB_LABELS[$i]}"$'\t'"${KB_PATHS[$i]}"; return 0; }
    done
    if [[ "$sel" == priv* ]]; then
        for i in {1..${#KB_PATHS}}; do
            [[ "${KB_LABELS[$i]}" == *priv* || "${KB_PATHS[$i]:t}" == *private* ]] && \
                { print -r -- "${KB_LABELS[$i]}"$'\t'"${KB_PATHS[$i]}"; return 0; }
        done
    fi
    return 1
}

# Point the per-repo path globals at a chosen root. Index filename follows the
# convention doc/<repo-dir-name>.md, with a doc/*.md fallback.
set_root_paths() {
    REPO="$1"
    NOTES="$REPO/tool-notes"
    CATS="$REPO/doc/categories"
    INDEX="$REPO/doc/${REPO:t}.md"
    if [[ ! -f "$INDEX" ]]; then
        local g; g=("$REPO"/doc/*.md(N)); (( ${#g} )) && INDEX="${g[1]}"
    fi
    TOOLS_README="$NOTES/README.md"
}

set_root_paths "$REPO"   # sensible single-root defaults; find/add refine via roots

# --- colors (only when stdout is a tty) ---
if [[ -t 1 ]]; then
    C_CMD=$'\e[1m'; C_PATH=$'\e[36m'; C_INT=$'\e[2m'; C_SEC=$'\e[33m'; C_RST=$'\e[0m'
else
    C_CMD=""; C_PATH=""; C_INT=""; C_SEC=""; C_RST=""
fi

die() { print -u2 "kb: $*"; exit 1; }

kebab() {
    # "AWS CLI" -> "aws-cli", "File and Directory" -> "file-and-directory"
    local s="${1:l}"
    s="${s//[^a-z0-9]##/-}"          # runs of non-alphanumeric -> single dash
    s="${s##-##}"; s="${s%%-##}"     # trim leading/trailing dashes
    print -r -- "$s"
}

# ---------------------------------------------------------------------------
# find
# ---------------------------------------------------------------------------
kb_find() {
    (( $# )) || die "usage: kb find <terms...>"
    kb_load_roots
    local query="$*" tmp; tmp=$(mktemp)
    local i root label f

    for i in {1..${#KB_PATHS}}; do
        label="${KB_LABELS[$i]}"; root="${KB_PATHS[$i]}"
        for f in "$root"/tool-notes/*.md(N); do
            [[ "${f:t}" == "README.md" ]] && continue
            awk -v q="$query" -v label="$label" -v file="tool-notes/${f:t}" '
            function lc(s){ return tolower(s) }
            BEGIN { n=split(lc(q), words, /[ \t]+/); section=""; title=""; inblock=0; indexable=0 }
            {
                if ($0 ~ /^```/) {
                    fence=$0; sub(/^```/,"",fence); gsub(/[ \t]+/,"",fence)
                    if (inblock) { inblock=0; indexable=0 }
                    else {
                        inblock=1
                        indexable = (fence=="" || fence=="bash" || fence=="sh" || fence=="shell" || fence=="zsh" || fence=="console")
                    }
                    next
                }
                if (!inblock) {
                    if (title=="" && $0 ~ /^# /) title=substr($0,3)
                    if ($0 ~ /^#{2,}[ ]/) { s=$0; sub(/^#+[ ]+/,"",s); section=s }
                    next
                }
                if (!indexable) next

                t=$0; gsub(/^[ \t]+|[ \t]+$/,"",t)
                if (t=="") next

                cmd=$0; intent=""
                if (match($0, /[ \t]+#/)) {
                    intent=substr($0, RSTART); gsub(/^[ \t]+/,"",intent)
                    cmd=substr($0, 1, RSTART-1)
                }
                gsub(/^[ \t]+|[ \t]+$/,"",cmd)
                if (cmd=="") next        # comment-only lines are context, not reusable commands

                sec = (section=="" ? title : section)
                hay=lc(cmd " " intent " " sec)
                for (i=1;i<=n;i++) if (index(hay, words[i])==0) next

                rank=1; cmdl=lc(cmd); allcmd=1
                for (i=1;i<=n;i++) if (index(cmdl, words[i])==0) { allcmd=0; break }
                if (allcmd && cmd!="") rank=2

                printf("%d\t%s\t%s\t%d\t%s\t%s\t%s\n", rank, label, file, FNR, sec, cmd, intent)
            }
            ' "$f" >> "$tmp"
        done
    done

    if [[ ! -s "$tmp" ]]; then
        rm -f "$tmp"; print "kb: no examples match: $query"; return 1
    fi

    # Only show the repo tag when more than one root is configured.
    local show_label=0; (( ${#KB_PATHS} > 1 )) && show_label=1
    local count; count=$(grep -c . "$tmp")
    sort -t$'\t' -k1,1nr -k2,2 -k3,3 -k4,4n "$tmp" | awk -F'\t' \
        -v cc="$C_CMD" -v cp="$C_PATH" -v ci="$C_INT" -v cs="$C_SEC" -v cr="$C_RST" -v showl="$show_label" '
        {
            label=$2; file=$3; line=$4; sec=$5; cmd=$6; intent=$7
            printf("%s%s%s", cc, cmd, cr)
            if (intent != "") printf("   %s%s%s", ci, intent, cr)
            printf("\n  ")
            if (showl) printf("%s[%s]%s ", ci, label, cr)
            printf("%s%s:%s%s", cp, file, line, cr)
            if (sec != "") printf("  %s·  %s%s%s", ci, cr cs, sec, cr)
            printf("\n\n")
        }'
    print -- "${C_INT}${count} match(es).${C_RST}"
    rm -f "$tmp"
}

# ---------------------------------------------------------------------------
# add (editor-first capture)
# ---------------------------------------------------------------------------
open_at() {
    # open_at <file> <line>
    local file="$1" line="$2" ed="${EDITOR:-vi}"
    case "$ed" in
        *code*)        command code -g "$file:$line" ;;
        *vi*|*nvim*)   command $ed "+$line" "$file" ;;
        *)             command $ed "$file" ;;
    esac
}

kb_add() {
    local tool="" section="" category="" desc="" dry=0 sel=""
    while (( $# )); do
        case "$1" in
            --section)  section="$2"; shift 2 ;;
            --category) category="$2"; shift 2 ;;
            --desc)     desc="$2"; shift 2 ;;
            --private)  sel="private"; shift ;;
            --repo)     sel="$2"; shift 2 ;;
            --dry-run)  dry=1; shift ;;
            -*)         die "unknown option: $1" ;;
            *)          [[ -z "$tool" ]] && tool="$1" || die "unexpected arg: $1"; shift ;;
        esac
    done
    [[ -n "$tool" ]] || die "usage: kb add <tool> [--private | --repo <label>] [--section H] [--category C] [--desc D] [--dry-run]"

    # Resolve destination repo (default = first/public root; --private opts in).
    kb_load_roots
    local rt; rt=$(kb_root_for "$sel") || \
        die "no ${sel:-default} repo configured (roots: ${(j:, :)KB_LABELS}); see ~/.config/kb/roots"
    local label="${rt%%$'\t'*}" root="${rt#*$'\t'}"
    set_root_paths "$root"
    print -- "${C_SEC}→ ${label} repo:${C_RST} ${root/#$HOME/~}"

    local note="$NOTES/$tool.md"
    local templ="command-here            # what it does / why you kept it"

    if [[ -f "$note" ]]; then
        # Existing note: insert a template line at the end of a bash block, then open at it.
        # Returns the line number of the target block's CLOSING fence (0 if none found).
        local insert_line
        insert_line=$(awk -v want="$section" '
            function lc(s){return tolower(s)}
            BEGIN{ inblock=0; idx=0; sec=""; target=0; last=0 }
            {
                if ($0 ~ /^```/) {
                    fence=$0; sub(/^```/,"",fence); gsub(/[ \t]+/,"",fence)
                    if (inblock) {
                        inblock=0
                        if (idx) { last=NR; if (want!="" && lc(sec)==lc(want)) target=NR }
                    } else {
                        inblock=1
                        idx=(fence==""||fence=="bash"||fence=="sh"||fence=="shell"||fence=="zsh"||fence=="console")
                    }
                    next
                }
                if (!inblock && $0 ~ /^#{2,}[ ]/) { s=$0; sub(/^#+[ ]+/,"",s); sec=s }
            }
            END{ print (want!="" ? target : last) }
        ' "$note")

        if [[ "$insert_line" == "0" || -z "$insert_line" ]]; then
            if [[ -n "$section" ]]; then
                die "no bash example block under section \"$section\" in ${note#$REPO/} (check the heading, or omit --section)"
            else
                die "no bash example block in ${note#$REPO/}; add one first or pass --section"
            fi
        fi

        if (( dry )); then
            print "DRY-RUN: would insert into ${note#$REPO/} before line $insert_line:"
            print "    $templ"
            print "DRY-RUN: would open editor at line $insert_line"
            return 0
        fi
        # Insert template line just before the block's closing fence.
        local tmp; tmp=$(mktemp)
        awk -v at="$insert_line" -v line="$templ" 'NR==at{ print line } { print }' "$note" > "$tmp" && mv "$tmp" "$note"
        print "Added template to ${note#$REPO/}:$insert_line — fill it in."
        open_at "$note" "$insert_line"
        return 0
    fi

    # New note: scaffold + wire category + README + index.
    [[ -n "$category" ]] || { print -n "Category for new tool '$tool' (e.g. Network): "; read -r category; }
    [[ -n "$category" ]] || die "a category is required for a new tool"
    [[ -n "$desc" ]] || desc="<one-line description — what it does / what it replaces>"

    local cat_kebab cat_file
    cat_kebab=$(kebab "$category")
    cat_file="$CATS/$cat_kebab.md"

    if (( dry )); then
        print "DRY-RUN plan for new tool '$tool':"
        print "  create  ${note#$REPO/}"
        if [[ -f "$cat_file" ]]; then print "  append bullet to ${cat_file#$REPO/}"
        else print "  create  ${cat_file#$REPO/} (H1: $category) + link it in ${INDEX#$REPO/}"; fi
        print "  append bullet to ${TOOLS_README#$REPO/}"
        return 0
    fi

    # 1) tool note
    cat > "$note" <<EOF
# $tool

$desc

## Examples

\`\`\`bash
$templ
\`\`\`
EOF

    # 2) category file (+ index wiring if new)
    local bullet="- [$tool](../../tool-notes/$tool.md) — ${desc}"
    if [[ -f "$cat_file" ]]; then
        print -r -- "$bullet" >> "$cat_file"
    else
        cat > "$cat_file" <<EOF
# $category

${category} tools.

$bullet
EOF
        wire_index_category "$category" "$cat_kebab"
    fi

    # 3) alphabetical bullet in tool-notes/README.md
    add_readme_bullet "$tool" "$desc"

    print "Scaffolded new tool '$tool' in category '$category'."
    print "  ${note#$REPO/}"
    print "  ${cat_file#$REPO/}"
    open_at "$note" 8   # the template line inside the bash block
}

wire_index_category() {
    # Convert a placeholder line to a link, or insert a new link in alpha order.
    local name="$1" kebab="$2" link="- [$1](categories/$2.md)"
    local tmp; tmp=$(mktemp)
    awk -v name="$name" -v link="$link" '
        function lc(s){return tolower(s)}
        BEGIN{ done=0; incat=0 }
        {
            if ($0 ~ /^## /) {
                if ($0 ~ /^## Categories/) { incat=1; print; next }
                else { if (incat && !done) { print link; done=1 } incat=0 }
            }
            if (incat && !done) {
                if ($0 ~ /^_No categories/) { print link; done=1; next }   # replace placeholder in place
                if ($0 ~ /^- /) {
                    item=$0; sub(/^- /,"",item)
                    label=item; sub(/\].*$/,"",label); sub(/^\[/,"",label)
                    if (item==name) { print link; done=1; next }   # replace a plain placeholder
                    cmp = (item ~ /^\[/) ? label : item
                    if (lc(cmp) > lc(name)) { print link; done=1 }
                }
            }
            print
        }
        END{ if (!done) print link }
    ' "$INDEX" > "$tmp" && mv "$tmp" "$INDEX"
    print "  linked category in ${INDEX#$REPO/}"
}

add_readme_bullet() {
    local tool="$1" desc="$2" bullet="- [$1]($1.md) — $2"
    if [[ ! -f "$TOOLS_README" ]]; then
        printf '# tool-notes\n\nThe notes themselves. One file per tool, with real-world examples.\n\n## Tools\n\n%s\n' "$bullet" > "$TOOLS_README"
        print "  created ${TOOLS_README#$REPO/}"
        return 0
    fi
    local tmp; tmp=$(mktemp)
    awk -v tool="$tool" -v bullet="$bullet" '
        function lc(s){return tolower(s)}
        BEGIN{ inlist=0; done=0 }
        {
            if ($0 ~ /^## /) {
                if ($0 ~ /^## Tools/) { inlist=1; print; next }
                else { if (inlist && !done) { print bullet; done=1 } inlist=0 }
            }
            if (inlist && !done) {
                if ($0 ~ /^_No tool/) { print bullet; done=1; next }   # replace placeholder in place
                if ($0 ~ /^- \[/) {
                    item=$0; sub(/^- \[/,"",item); sub(/\].*$/,"",item)
                    if (lc(item) > lc(tool)) { print bullet; done=1 }
                }
            }
            print
        }
        END{ if (!done) print bullet }
    ' "$TOOLS_README" > "$tmp" && mv "$tmp" "$TOOLS_README"
    print "  added bullet in ${TOOLS_README#$REPO/}"
}

kb_open() {
    (( $# )) || die "usage: kb open <tool>"
    kb_load_roots
    local i note
    for i in {1..${#KB_PATHS}}; do
        note="${KB_PATHS[$i]}/tool-notes/$1.md"
        [[ -f "$note" ]] && { open_at "$note" 1; return 0; }
    done
    die "no tool note: $1 (try: kb find $1)"
}

kb_help() {
    kb_load_roots
    print -r -- "kb — get/put for your knowledge-base notes (a curated, searchable shell history).

usage:
  kb find <terms...>            Search examples across all roots; prints command + intent
                                + a tool-notes/<x>.md:<line> pointer (tagged by repo).
  kb add  <tool> [opts]         Editor-first capture; scaffolds + wires a new tool/category.
  kb open <tool>                Open a tool note in \$EDITOR (searches all roots).
  kb help                       This text.

add options:
  --private                     Write to the private root instead of the default (public).
  --repo <label>                Write to the root with this label.
  --section \"<Heading>\"         Capture under a specific section (default: last bash block).
  --category \"<Category>\"       Category for a NEW tool (else prompted).
  --desc \"<one-liner>\"          Description for a NEW tool's title line.
  --dry-run                     Print planned changes; write nothing.

configured roots (first = default write target):"
    local i
    for i in {1..${#KB_PATHS}}; do
        print -r -- "  • ${KB_LABELS[$i]}$( (( i==1 )) && print -n '  (default)' ) — ${KB_PATHS[$i]/#$HOME/~}"
    done
    print -r -- "
roots come from \$KB_ROOTS or ~/.config/kb/roots (label = path, one per line)."
}

case "${1:-help}" in
    find|f|get)  shift; kb_find "$@" ;;
    add|put|a)   shift; kb_add "$@" ;;
    open|o)      shift; kb_open "$@" ;;
    help|-h|--help) kb_help ;;
    *)           die "unknown subcommand: $1 (try: kb help)" ;;
esac
